{
    "name": "@coinmeca/wallet-provider",
    "version": "0.1.701",
    "keywords": [
        "coinmeca",
        "ethereum",
        "web3",
        "wallet",
        "provider",
        "wallet-provider"
    ],
    "repository": {
        "type": "git",
        "url": "https://github.com/coinmeca/wallet-provider"
    },
    "license": "MIT",
    "sideEffects": false,
    "type": "module",
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "module": "./dist/index.js",
    "files": [
        "./dist"
    ],
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "import": "./dist/index.js",
            "default": "./dist/index.js"
        },
        "./adapter": {
            "types": "./dist/adapter.d.ts",
            "import": "./dist/adapter.js",
            "default": "./dist/adapter.js"
        },
        "./provider": {
            "types": "./dist/provider.d.ts",
            "import": "./dist/provider.js",
            "default": "./dist/provider.js"
        },
        "./telegram": {
            "types": "./dist/telegram.d.ts",
            "import": "./dist/telegram.js",
            "default": "./dist/telegram.js"
        },
        "./chains": {
            "types": "./dist/chains.d.ts",
            "import": "./dist/chains.js",
            "default": "./dist/chains.js"
        }
    },
    "typesVersions": {
        "*": {
            "adapter": [
                "./dist/adapter.d.ts"
            ],
            "provider": [
                "./dist/provider.d.ts"
            ],
            "telegram": [
                "./dist/telegram.d.ts"
            ],
            "chains": [
                "./dist/chains.d.ts"
            ]
        }
    },
    "scripts": {
        "start": "next start",
        "dev": "next dev",
        "check": "npx tsc --watch",
        "build": "yarn clean && npx tsc --build --force",
        "deploy": "npm publish",
        "clean": "rm -rf ./dist ./build ./.next ./node_modules/.cache ./tsconfig.tsbuildinfo"
    },
    "dependencies": {
        "@coinmeca/wallet-sdk": "0.1.701",
        "next": "14.2.20",
        "react": "18.3.1",
        "react-dom": "18.3.1"
    },
    "devDependencies": {
        "@types/node": "22.10.2",
        "@types/react": "18.3.17",
        "@types/react-dom": "18.3.5",
        "@types/telegram-web-app": "^7.10.1",
        "eslint": "9.17.0",
        "eslint-config-next": "14.2.20",
        "tsx": "^4.19.2",
        "typescript": "^5.7.2"
    },
    "packageManager": "yarn@4.5.1"
}
